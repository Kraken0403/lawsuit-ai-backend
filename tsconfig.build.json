{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": [
    "src/scripts/**",
    "src/**/*_old.*",
    "src/router/legalRouter_old.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}