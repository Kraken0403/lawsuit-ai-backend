generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id                       String                  @id @default(cuid()) @db.VarChar(191)
  externalUserId           String?                 @unique @map("external_user_id") @db.VarChar(120)
  authProvider             String                  @default("local") @map("auth_provider") @db.VarChar(50)
  username                 String?                 @db.VarChar(120)
  email                    String?                 @unique @db.VarChar(320)
  name                     String?                 @db.VarChar(120)
  passwordHash             String?                 @map("password_hash") @db.VarChar(255)
  hasAiAccess              Boolean                 @default(true) @map("has_ai_access")
  subscriptionStatus       String?                 @map("subscription_status") @db.VarChar(50)
  allowedCourtIdsJson      String?                 @map("allowed_court_ids_json") @db.NVarChar(Max)
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")
  creditsRemaining         Int                     @default(30) @map("credits_remaining")

  sessions                 Session[]
  conversations            Conversation[]
  bookmarkedCases          BookmarkedCase[]
  promptRuns               PromptRun[]
  firmSettings             FirmSettings?
  ownedDraftTemplates      DraftTemplate[]         @relation("OwnedDraftTemplates")
  draftDocuments           DraftDocument[]
  draftAttachments         DraftAttachment[]
  suggestedCaseFeedbacks   SuggestedCaseFeedback[]

  @@map("users")
}

model Session {
  id         String    @id @default(cuid()) @db.VarChar(191)
  userId     String    @map("user_id") @db.VarChar(191)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(128)
  userAgent  String?   @map("user_agent") @db.NVarChar(Max)
  ipAddress  String?   @map("ip_address") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime  @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@map("sessions")
}

model Conversation {
  id               String            @id @default(cuid()) @db.VarChar(191)
  userId           String            @map("user_id") @db.VarChar(191)
  title            String            @default("New chat") @db.VarChar(200)
  chatMode         String            @default("JUDGMENT") @map("chat_mode") @db.VarChar(32)
  shareToken       String?           @map("share_token") @db.VarChar(128)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  archivedAt       DateTime?         @map("archived_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages         Message[]
  promptRuns       PromptRun[]
  draftDocuments   DraftDocument[]
  draftAttachments DraftAttachment[]

  @@index([userId, chatMode, updatedAt])
  @@index([shareToken])
  @@map("conversations")
}

model AssistantMessageFeedback {
  id                 String  @id @default(cuid()) @db.VarChar(191)
  userId             String? @map("user_id") @db.VarChar(191)
  conversationId     String? @map("conversation_id") @db.VarChar(191)
  mode               String  @db.VarChar(32)
  caseId             String? @map("case_id") @db.VarChar(64)
  userMessageId      String? @map("user_message_id") @db.VarChar(191)
  assistantMessageId String  @map("assistant_message_id") @db.VarChar(191)
  reaction           String? @db.VarChar(16)
  comment            String? @db.NVarChar(Max)
  fingerprint        String? @db.VarChar(500)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([userId, assistantMessageId], map: "uq_assistant_feedback_user_message")
  @@index([assistantMessageId])
  @@index([caseId])
  @@map("assistant_message_feedback")
}

model SuggestedCaseFeedback {
  id                 String   @id @default(cuid()) @db.VarChar(191)
  userId             String?  @map("user_id") @db.VarChar(191)
  caseId             String   @map("case_id") @db.VarChar(64)
  fingerprint        String?  @db.VarChar(500)
  feedback           String   @db.VarChar(16)
  comment            String?  @db.NVarChar(Max)
  userMessageId      String?  @map("user_message_id") @db.VarChar(191)
  assistantMessageId String?  @map("assistant_message_id") @db.VarChar(191)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, caseId, assistantMessageId], map: "uq_suggested_case_feedback_user_case_assistant")
  @@index([userId, createdAt])
  @@index([caseId])
  @@map("suggested_case_feedback")
}

model Message {
  id                    String       @id @default(cuid()) @db.VarChar(191)
  conversationId        String       @map("conversation_id") @db.VarChar(191)
  role                  String       @db.VarChar(20)
  content               String       @db.NVarChar(Max)
  sourcesJson           String?      @map("sources_json") @db.NVarChar(Max)
  caseDigestsJson       String?      @map("case_digests_json") @db.NVarChar(Max)
  traceJson             String?      @map("trace_json") @db.NVarChar(Max)
  createdAt             DateTime     @default(now()) @map("created_at")

  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  promptRunsAsUser      PromptRun[]  @relation("UserMessagePromptRuns")
  promptRunsAsAssistant PromptRun[]  @relation("AssistantMessagePromptRuns")

  @@index([conversationId, createdAt])
  @@map("messages")
}

model BookmarkedCase {
  id             String   @id @default(cuid()) @db.VarChar(191)
  userId         String   @map("user_id") @db.VarChar(191)
  fingerprint    String   @db.VarChar(500)
  externalCaseId String?  @map("external_case_id") @db.VarChar(64)
  title          String   @db.NVarChar(Max)
  citation       String   @db.NVarChar(Max)
  payloadJson    String?  @map("payload_json") @db.NVarChar(Max)
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, fingerprint], name: "userId_fingerprint")
  @@index([userId, createdAt])
  @@map("bookmarked_cases")
}

model PromptRun {
  id                 String   @id @default(cuid()) @db.VarChar(191)
  userId             String?  @map("user_id") @db.VarChar(191)
  conversationId     String?  @map("conversation_id") @db.VarChar(191)
  userMessageId      String?  @map("user_message_id") @db.VarChar(191)
  assistantMessageId String?  @map("assistant_message_id") @db.VarChar(191)
  originalQuery      String   @map("original_query") @db.NVarChar(Max)
  effectiveQuery     String?  @map("effective_query") @db.NVarChar(Max)
  mode               String?  @db.VarChar(64)
  chatMode           String?  @map("chat_mode") @db.VarChar(32)
  routerJson         String?  @map("router_json") @db.NVarChar(Max)
  filtersJson        String?  @map("filters_json") @db.NVarChar(Max)
  notesJson          String?  @map("notes_json") @db.NVarChar(Max)
  sourcesJson        String?  @map("sources_json") @db.NVarChar(Max)
  caseDigestsJson    String?  @map("case_digests_json") @db.NVarChar(Max)
  confidence         Float?
  createdAt          DateTime @default(now()) @map("created_at")

  user             User?         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userMessage      Message?      @relation("UserMessagePromptRuns", fields: [userMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assistantMessage Message?      @relation("AssistantMessagePromptRuns", fields: [assistantMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([chatMode, createdAt])
  @@map("prompt_runs")
}

model CaseSummary {
  id               String   @id @default(cuid()) @db.VarChar(191)
  caseId           String   @db.VarChar(64)
  fileName         String?  @db.VarChar(64)
  title            String?  @db.NVarChar(Max)
  citation         String?  @db.VarChar(255)
  summaryType      String   @db.VarChar(32)
  sourceType       String   @default("qdrant") @db.VarChar(32)
  sourceHash       String   @db.VarChar(64)
  modelName        String   @db.VarChar(100)
  status           String   @default("ready") @db.VarChar(20)
  sectionsJson     String   @db.NVarChar(Max)
  renderedMarkdown String   @db.NVarChar(Max)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([caseId, summaryType, sourceHash], map: "uq_case_summary_case_type_hash")
  @@index([caseId, summaryType], map: "idx_case_summary_case_type")
  @@map("casesummary")
}

model FirmSettings {
  id                          String   @id @default(cuid()) @db.VarChar(191)
  userId                      String   @unique @map("user_id") @db.VarChar(191)
  firmName                    String?  @db.VarChar(200)
  advocateName                String?  @map("advocate_name") @db.VarChar(200)
  enrollmentNumber            String?  @map("enrollment_number") @db.VarChar(100)
  address                     String?  @db.NVarChar(Max)
  email                       String?  @db.VarChar(320)
  phone                       String?  @db.VarChar(50)
  website                     String?  @db.VarChar(255)
  logoUrl                     String?  @map("logo_url") @db.VarChar(500)
  headerText                  String?  @map("header_text") @db.NVarChar(Max)
  footerText                  String?  @map("footer_text") @db.NVarChar(Max)
  signatureText               String?  @map("signature_text") @db.NVarChar(Max)

  draftingBrandingMode        String   @default("NONE") @map("drafting_branding_mode") @db.VarChar(32)
  draftingHeaderImageUrl      String?  @map("drafting_header_image_url") @db.VarChar(500)
  draftingFooterImageUrl      String?  @map("drafting_footer_image_url") @db.VarChar(500)
  draftingLetterheadImageUrl  String?  @map("drafting_letterhead_image_url") @db.VarChar(500)

  draftingHeaderHeightPx      Int?     @map("drafting_header_height_px")
  draftingFooterHeightPx      Int?     @map("drafting_footer_height_px")
  draftingLetterheadHeightPx  Int?     @map("drafting_letterhead_height_px")

  draftingLockBranding        Boolean  @default(true) @map("drafting_lock_branding")

  draftingDefaultTone         String?  @map("drafting_default_tone") @db.VarChar(50)
  draftingDefaultJurisdiction String?  @map("drafting_default_jurisdiction") @db.VarChar(120)
  draftingDefaultForum        String?  @map("drafting_default_forum") @db.VarChar(120)

  draftingSignatureImageUrl   String?  @map("drafting_signature_image_url") @db.VarChar(500)

  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("firm_settings")
}

model DraftTemplate {
  id                        String   @id @default(cuid()) @db.VarChar(191)
  ownerUserId               String?  @map("owner_user_id") @db.VarChar(191)
  source                    String   @db.VarChar(32)
  title                     String   @db.VarChar(255)
  family                    String   @db.VarChar(64)
  subtype                   String?  @db.VarChar(120)
  jurisdiction              String?  @db.VarChar(120)
  forum                     String?  @db.VarChar(120)
  language                  String?  @db.VarChar(50)
  tagsJson                  String?  @map("tags_json") @db.NVarChar(Max)
  useWhenJson               String?  @map("use_when_json") @db.NVarChar(Max)
  notForJson                String?  @map("not_for_json") @db.NVarChar(Max)
  summary                   String?  @db.NVarChar(Max)
  precedentStrength         String   @default("STANDARD") @map("precedent_strength") @db.VarChar(32)
  rawText                   String   @map("raw_text") @db.NVarChar(Max)
  normalizedText            String?  @map("normalized_text") @db.NVarChar(Max)
  placeholdersJson          String?  @map("placeholders_json") @db.NVarChar(Max)
  clauseBlocksJson          String?  @map("clause_blocks_json") @db.NVarChar(Max)
  executionRequirementsJson String?  @map("execution_requirements_json") @db.NVarChar(Max)
  riskNotesJson             String?  @map("risk_notes_json") @db.NVarChar(Max)
  sourceRef                 String?  @map("source_ref") @db.VarChar(255)
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  owner       User?             @relation("OwnedDraftTemplates", fields: [ownerUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attachments DraftAttachment[]

  @@index([source, family, subtype, isActive])
  @@index([ownerUserId, source, isActive])
  @@map("draft_templates")
}

model DraftDocument {
  id                         String   @id @default(cuid()) @db.VarChar(191)
  userId                     String   @map("user_id") @db.VarChar(191)
  conversationId             String?  @map("conversation_id") @db.VarChar(191)
  title                      String   @db.VarChar(255)
  family                     String   @db.VarChar(64)
  subtype                    String?  @db.VarChar(120)
  strategy                   String?  @db.VarChar(64)
  matchLevel                 String?  @map("match_level") @db.VarChar(32)
  sourceTemplateIdsJson      String?  @map("source_template_ids_json") @db.NVarChar(Max)
  inputDataJson              String?  @map("input_data_json") @db.NVarChar(Max)
  draftingPlanJson           String?  @map("drafting_plan_json") @db.NVarChar(Max)
  draftMarkdown              String?  @map("draft_markdown") @db.NVarChar(Max)
  draftHtml                  String?  @map("draft_html") @db.NVarChar(Max)
  exportPdfUrl               String?  @map("export_pdf_url") @db.VarChar(500)
  exportDocxUrl              String?  @map("export_docx_url") @db.VarChar(500)
  status                     String   @default("DRAFT") @db.VarChar(32)
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  editorJson                 String?  @map("editor_json") @db.NVarChar(Max)
  unresolvedPlaceholdersJson String?  @map("unresolved_placeholders_json") @db.NVarChar(Max)

  user         User                   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  conversation Conversation?          @relation(fields: [conversationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions     DraftDocumentVersion[]

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@map("draft_documents")
}

model DraftAttachment {
  id             String   @id @default(cuid()) @db.VarChar(191)
  userId         String?  @map("user_id") @db.VarChar(191)
  conversationId String?  @map("conversation_id") @db.VarChar(191)
  templateId     String?  @map("template_id") @db.VarChar(191)
  fileName       String   @map("file_name") @db.VarChar(255)
  mimeType       String   @map("mime_type") @db.VarChar(120)
  storageUrl     String   @map("storage_url") @db.VarChar(500)
  extractedText  String?  @map("extracted_text") @db.NVarChar(Max)
  parsedJson     String?  @map("parsed_json") @db.NVarChar(Max)
  createdAt      DateTime @default(now()) @map("created_at")

  user         User?          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  conversation Conversation?  @relation(fields: [conversationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  template     DraftTemplate? @relation(fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, conversationId, createdAt])
  @@index([templateId])
  @@map("draft_attachments")
}

model DraftDocumentVersion {
  id                         String   @id @default(cuid()) @db.VarChar(191)
  draftDocumentId            String   @map("draft_document_id") @db.VarChar(191)
  versionNumber              Int      @map("version_number")
  title                      String   @db.VarChar(255)
  family                     String   @db.VarChar(64)
  subtype                    String?  @db.VarChar(120)
  strategy                   String?  @db.VarChar(64)
  matchLevel                 String?  @map("match_level") @db.VarChar(32)
  sourceTemplateIdsJson      String?  @map("source_template_ids_json") @db.NVarChar(Max)
  inputDataJson              String?  @map("input_data_json") @db.NVarChar(Max)
  draftingPlanJson           String?  @map("drafting_plan_json") @db.NVarChar(Max)
  draftMarkdown              String?  @map("draft_markdown") @db.NVarChar(Max)
  draftHtml                  String?  @map("draft_html") @db.NVarChar(Max)
  createdByUserId            String?  @map("created_by_user_id") @db.VarChar(191)
  createdAt                  DateTime @default(now()) @map("created_at")
  editorJson                 String?  @map("editor_json") @db.NVarChar(Max)
  unresolvedPlaceholdersJson String?  @map("unresolved_placeholders_json") @db.NVarChar(Max)

  draftDocument DraftDocument @relation(fields: [draftDocumentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([draftDocumentId, versionNumber], map: "uq_draft_document_version")
  @@index([draftDocumentId, createdAt], map: "idx_draft_document_versions_doc_created")
  @@map("draft_document_versions")
}